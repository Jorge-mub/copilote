Private Sub btAgregar_Click()
    Dim condicion As String
    Dim tama As Long
    
    If Me.ComboBox1.Value = "" Or Me.ComboBox1.ListIndex = -1 Then
        MsgBox "Artículo no encontrado", vbExclamation, "Error"
        Exit Sub
    End If
    
    If Me.TextBox1.Value = "" Then
        MsgBox "Cantidad no encontrada", vbExclamation, "Error"
        Exit Sub
    End If
    
    If Not IsNumeric(Me.TextBox1.Value) Or InStr(Me.TextBox1.Value, ".") > 0 Or Val(Me.TextBox1.Value) <= 0 Then
        MsgBox "Cantidad no válida. Debe ingresar un número entero.", vbExclamation, "Error"
        Exit Sub
    End If
    
    If Me.cmbUsuario.Value = "" Or Me.cmbUsuario.ListIndex = -1 Then
        MsgBox "Usuario no encontrado", vbExclamation, "Error"
        Exit Sub
    End If
    
    If Val(Me.TextBox1.Value) > 100 Then
        If MsgBox("Se detectó un ingreso de unidades superior a 100, ¿Estas seguro de la cantidad ingresada?", vbYesNo + vbQuestion, "Confirmación") = vbNo Then
            Exit Sub
        End If
    End If
    
    cat = Me.ComboBox1.Value
    dog = Me.TextBox1.Value
    check = Me.CheckBox1.Value
    bird = Format(Now, "dd/mm/yyyy hh:mm:ss")
    
    tama = Me.caja1.ListCount
    
    If check = False Then
        condicion = "Nuevo"
    Else
        condicion = "Reformulado"
    End If
    
    Me.caja1.AddItem cat
    Me.caja1.List(tama, 1) = condicion
    Me.caja1.List(tama, 2) = dog
    Me.caja1.List(tama, 3) = Me.cmbUsuario.Value
    
    Me.ComboBox1.Value = ""
    Me.TextBox1.Value = ""
End Sub

Private Sub commandButton1_click()
    Dim tblConsumo As ListObject
    Dim arrNuevosConsumos() As Variant
    Dim i As Long
    Dim tipoMovimiento As String
    Dim cantidad As Double
    Dim nItems As Long
    Dim newRow As Range
   
    nItems = caja1.ListCount
    If nItems = 0 Then Exit Sub
    
    Set tblConsumo = consumo.ListObjects("dailyConsumption")
    ReDim arrNuevosConsumos(1 To nItems, 1 To 6)
    ReDim vector(1 To nItems, 1 To 4)
    
    For i = 1 To nItems
        arrNuevosConsumos(i, 1) = caja1.List(i - 1, 0)
        arrNuevosConsumos(i, 2) = caja1.List(i - 1, 1)
        
        cantidad = Val(caja1.List(i - 1, 2))
        If modo = True Then
            tipoMovimiento = "Retiro"
            cantidad = -cantidad
        Else
            tipoMovimiento = "Entrada"
        End If
        
        arrNuevosConsumos(i, 3) = tipoMovimiento
        arrNuevosConsumos(i, 4) = cantidad
        arrNuevosConsumos(i, 5) = Now
        arrNuevosConsumos(i, 6) = caja1.List(i - 1, 3)
        
        vector(i, 1) = arrNuevosConsumos(i, 1)
        vector(i, 2) = arrNuevosConsumos(i, 2)
        vector(i, 3) = Abs(cantidad)
        vector(i, 4) = arrNuevosConsumos(i, 6)
    Next i
    
    Set newRow = tblConsumo.ListRows.Add.Range
    If nItems > 1 Then
        newRow.Resize(nItems, 6).Value = arrNuevosConsumos
    Else
        newRow.Resize(1, 6).Value = arrNuevosConsumos
    End If
    
    tblConsumo.DataBodyRange.Columns(5).NumberFormat = "dd/mm/yyyy hh:mm:ss"
    
    Me.ComboBox1.Value = ""
    Me.TextBox1.Value = ""
    Me.CheckBox1.Value = False
    Me.cmbUsuario.Value = ""
    
    Call consumos
    
    Unload Me
    Almacen.Show vbModeless
End Sub

Sub consumos()
    Dim tblExistencias As ListObject
    Dim vExistencias As Variant
    Dim dictRows As Object
    Dim i As Long, filaReal As Long
    Dim artBuscar As String
    
    Set tblExistencias = Exist.ListObjects("tabExistencias")
    If tblExistencias.ListRows.Count = 0 Then Exit Sub
    
    vExistencias = tblExistencias.DataBodyRange.Value
    Set dictRows = CreateObject("Scripting.Dictionary")
    dictRows.CompareMode = vbTextCompare
    
    For i = 1 To UBound(vExistencias, 1)
        If Not IsEmpty(vExistencias(i, 4)) Then
            dictRows(CStr(vExistencias(i, 4))) = i
        End If
    Next i
    
    For i = 1 To UBound(vector, 1)
        artBuscar = CStr(vector(i, 1))
        
        If dictRows.Exists(artBuscar) Then
            filaReal = dictRows(artBuscar)
            
            If vector(i, 2) = "Nuevo" Then
                If modo Then
                    vExistencias(filaReal, 8) = vExistencias(filaReal, 8) - vector(i, 3)
                Else
                    vExistencias(filaReal, 8) = vExistencias(filaReal, 8) + vector(i, 3)
                End If
            Else
                If modo Then
                    vExistencias(filaReal, 9) = vExistencias(filaReal, 9) - vector(i, 3)
                Else
                    vExistencias(filaReal, 9) = vExistencias(filaReal, 9) + vector(i, 3)
                End If
            End If
        End If
    Next i
    
    tblExistencias.DataBodyRange.Value = vExistencias
    Me.caja1.Clear
End Sub


