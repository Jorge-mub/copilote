Sub FiltrarCaja2(ByVal sector As String)
    Dim tbl As ListObject
    Dim vData As Variant
    Dim i As Long, k As Long
    Dim tipoSel As String, grupoSel As String, lugarSel As String
    Dim tipoFila As String, grupoFila As String, lugarFila As String, artFila As String, artFila2 As String
    Dim arrArt() As Variant
    Dim cuenta As Long
    
    Set tbl = Exist.ListObjects("tabExistencias")
    If tbl.ListRows.Count < 1 Then Exit Sub
    
    vData = tbl.DataBodyRange.Value
    tipoSel = Me.cmbFiltroTipo.Value
    grupoSel = Me.cmbFiltroGrupo.Value
    lugarSel = GetControlTextValue("TextBox2")
    
    cuenta = 0
    For i = 1 To UBound(vData, 1)
        tipoFila = CStr(vData(i, 1))
        grupoFila = CStr(vData(i, 6))
        lugarFila = CStr(vData(i, 19))
            If (tipoSel = "" Or tipoFila = tipoSel) And _
           (grupoSel = "" Or grupoFila = grupoSel) And _
           (lugarSel = "" Or lugarFila = lugarSel) Then
            cuenta = cuenta + 1
        End If
    Next i
    
    If cuenta = 0 Then
        bloqueaEventos = True
        If sector = "Tipo" Then
            Me.cmbFiltroGrupo.Value = ""
            grupoSel = ""
        ElseIf sector = "Grupo" Then
            Me.cmbFiltroTipo.Value = ""
            tipoSel = ""
        End If
        bloqueaEventos = False
        
        cuenta = 0
        For i = 1 To UBound(vData, 1)
            tipoFila = CStr(vData(i, 1))
            grupoFila = CStr(vData(i, 6))
            If (tipoSel = "" Or tipoFila = tipoSel) And (grupoSel = "" Or grupoFila = grupoSel) Then
                cuenta = cuenta + 1
            End If
        Next i
    End If
    
    Me.caja2.Clear
    If cuenta > 0 Then
        ReDim arrArt(1 To cuenta, 1 To 2)
        k = 1
        For i = 1 To UBound(vData, 1)
            tipoFila = CStr(vData(i, 1))
            grupoFila = CStr(vData(i, 6))
            lugarFila = CStr(vData(i, 19))
            artFila = CStr(vData(i, 4))
            artFila2 = CStr(vData(i, 21))
            If (tipoSel = "" Or tipoFila = tipoSel) And _
               (grupoSel = "" Or grupoFila = grupoSel) And _
               (lugarSel = "" Or lugarFila = lugarSel) Then
                arrArt(k, 1) = artFila
                arrArt(k, 2) = artFila2
                k = k + 1
            End If
        Next i
        Me.caja2.List = arrArt
    End If
End Sub

