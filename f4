Private Function GetControlTextValue(controlName As String) As String
    Dim ctl As Object
    On Error Resume Next
    Set ctl = Me.Controls(controlName)
    If Err.Number = 0 Then
        GetControlTextValue = Trim(CStr(ctl.Value))
    Else
        GetControlTextValue = ""
    End If
    On Error GoTo 0
End Function

