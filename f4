Function SortedKeysFromDict(ByVal dictObj As Object) As Variant
    Dim keysArr As Variant
    Dim i As Long, j As Long
    Dim temp As String

    keysArr = dictObj.keys
    If UBound(keysArr) > LBound(keysArr) Then
        For i = LBound(keysArr) To UBound(keysArr) - 1
            For j = i + 1 To UBound(keysArr)
                If CStr(keysArr(i)) > CStr(keysArr(j)) Then
                    temp = keysArr(i)
                    keysArr(i) = keysArr(j)
                    keysArr(j) = temp
                End If
            Next j
        Next i
    End If
    SortedKeysFromDict = keysArr
End Function

